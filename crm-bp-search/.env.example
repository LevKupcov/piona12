# Скопируйте в .env после регистрации приложения на dev.1c-bitrix.ru

APP_CLIENT_ID=

APP_CLIENT_SECRET=



# Базовый URL public/ (для ngrok — без завершающего слэша)

# APP_PUBLIC_BASE=https://your-public-https-domain/work/crm-bp-search/public



# Или укажите каждый endpoint отдельно:

APP_HANDLER_URL=https://your-public-https-domain/work/crm-bp-search/public/handler.php

APP_INSTALL_URL=https://your-public-https-domain/work/crm-bp-search/public/install.php

APP_PLACEMENT_URL=https://your-public-https-domain/work/crm-bp-search/public/placement.php

# ID шаблона БП «Поиск CRM» (из URL edit/24/ → 24)
BP_LAUNCH_TEMPLATE_ID=24

